{
  "name": "valid-gtin",
  "version": "2.0.3",
  "type": "module",
  "scripts": {
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run minify",
    "lint": "eslint",
    "minify": "terser src/index.js -o dist/index.js -c -m",
    "presize": "npm run minify",
    "size": "size-limit",
    "pretest": "npm run minify",
    "test": "vitest run"
  },
  "author": "0xflotus",
  "keywords": [
    "gtin",
    "validate"
  ],
  "repository": "github:0xflotus/valid-gtin",
  "main": "dist/index.js",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@size-limit/preset-small-lib": "12.0.1",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "10.1.0",
    "fast-check": "4.6.0",
    "size-limit": "12.0.1",
    "terser": "5.46.1",
    "vitest": "4.1.2"
  }
}
